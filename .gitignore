chalamandramagistral@penguin:~/microcosmos_elite$ from qiskit import QuantumCircuit

def aplicar_difusor_maestro(qc: QuantumCircuit, n: int) -> QuantumCircuit:
    """
    Aplica el difusor Grover (inversión sobre la media) para n qubits.
    Mapea |0...0> como estado marcado.
    """
    # 1. Cambio de base: H y X para mapear |0...0> a |1...1>
    for i in range(n):
        qc.h(i)
        qc.x(i)

    # 2. Multi-controlled Z (inversión de fase en |1...1>)
    qc.h(n-1)
    qc.mcx(list(range(n-1)), n-1)   # mcx = multi-controlled X (para Z equiv)
    qc.h(n-1)

    # 3. Restaurar base
    for i in range(n):
    print(qc.draw())usor_maestro(qc, n_qubits)
